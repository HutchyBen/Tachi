# reload the shell setup
setup-fish:
	fish dev/setup.fish
	exec fish

# Set up the codebase.
setup:
	./dev/bootstrap.sh -f

# Deploy stuff for putting tachi on a server.
#
# It's only private because I'm too lazy to make it modular
# and it's also just hyperspecific to _my_ opinions on how
# tachi should be deployed. I've already given you the docker
# containers!
enable-zkldi-deploy-code:
	git submodule update --init --remote deploy

# Same image as GHA `docker-push` (prod-unified). Context is always repo root via `git rev-parse`.
docker-build-server: assert-docker-host
	#!/usr/bin/env bash
	set -euo pipefail
	root="$(git rev-parse --show-toplevel)"
	exec docker build \
		-f "$root/docker/Dockerfile.server" \
		--target prod-unified \
		--build-arg "COMMIT_HASH=$(git -C "$root" rev-parse --short HEAD)" \
		-t tachi-server:local \
		"$root"
