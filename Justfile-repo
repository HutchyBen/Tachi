# reload the shell setup
setup-fish:
	fish dev/setup.fish
	exec fish

# Set up the codebase.
setup:
	./dev/bootstrap.sh -f

# Verify every Dockerfile in-repo that CI builds (excludes docs: see .github/workflows/docs.yml + Dockerfile.docs).
check-all-docker-builds: assert-docker-host
	#!/usr/bin/env bash
	set -euo pipefail
	root="$(git rev-parse --show-toplevel)"
	sha="$(git -C "$root" rev-parse --short HEAD)"
	echo "==> server (prod-unified)"
	docker build -f "$root/docker/Dockerfile.server" --target prod-unified \
		--build-arg "COMMIT_HASH=$sha" -t tachi-server:check "$root"
	echo "==> bot"
	docker build -f "$root/docker/Dockerfile.bot" -t tachi-bot:check "$root"
	echo "==> github-bot"
	docker build -f "$root/docker/Dockerfile.ghbot" -t tachi-ghbot:check "$root"
	echo "==> dev image"
	docker build -f "$root/Dockerfile.dev" -t tachi-dev:check "$root"
	echo "All Docker builds succeeded."
