{
	"compilerOptions": {
		"target": "ES2022",
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": false,
		// all packages run via bun directly from source - no emit needed
		"noEmit": true,
		"types": []
	}
}
