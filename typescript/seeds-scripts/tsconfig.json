{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "Preserve",
		"moduleResolution": "bundler",
		"noImplicitAny": false,
		"strictNullChecks": true,
		"allowJs": true,
		"strict": false,
		"paths": {
			"#*": ["./src/*"]
		}
	},
	"exclude": ["node_modules", "rerunners/**"]
}
