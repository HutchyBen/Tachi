# Core / Infrastructure
NODE_ENV=
PORT=
REDIS_URL=
POSTGRES_URL=
MIGRATIONS_DIR=
VERSION=
# YYYYMMDD-shortsha from commit date (UTC) + abbreviated SHA; COMMIT_HASH is still read as fallback
VERSION_DETAIL=
COMMIT_HASH=
LOG_LEVEL=

# Tachi server config (required)
TACHI_CAPTCHA_SECRET_KEY=
TACHI_SESSION_SECRET=
TACHI_OUR_URL=
TACHI_NAME=
TACHI_TYPE=
TACHI_GAME_GROUPS=
TACHI_IMPORT_TYPES=

# Tachi server config (optional)
TACHI_SIGNUPS_ENABLED=
TACHI_RATE_LIMIT=
TACHI_OAUTH_CLIENT_CAP=
TACHI_OPTIONS_ALWAYS_SUCCEEDS=
TACHI_ALLOW_RUNNING_OFFLINE=
TACHI_DISABLE_SCORE_IMPORT_RATE_LIMIT=
TACHI_ENABLE_METRICS=
TACHI_USC_QUEUE_SIZE=
TACHI_BEATORAJA_QUEUE_SIZE=
TACHI_MAX_GOAL_SUBSCRIPTIONS=
TACHI_MAX_QUEST_SUBSCRIPTIONS=
TACHI_MAX_FOLLOWING_AMOUNT=
TACHI_MAX_RIVALS=
TACHI_CLIENT_DEV_SERVER=

# CDN (required)
TACHI_CDN_WEB_LOCATION=
TACHI_CDN_SAVE_LOCATION_ENDPOINT=
TACHI_CDN_SAVE_LOCATION_ACCESS_KEY_ID=
TACHI_CDN_SAVE_LOCATION_SECRET_ACCESS_KEY=
TACHI_CDN_SAVE_LOCATION_BUCKET=
TACHI_CDN_SAVE_LOCATION_KEY_PREFIX=
TACHI_CDN_SAVE_LOCATION_REGION=
TACHI_CDN_SAVE_LOCATION_PRIVATE_ENDPOINT=
TACHI_CDN_SAVE_LOCATION_PRIVATE_ACCESS_KEY_ID=
TACHI_CDN_SAVE_LOCATION_PRIVATE_SECRET_ACCESS_KEY=
TACHI_CDN_SAVE_LOCATION_PRIVATE_BUCKET=
TACHI_CDN_SAVE_LOCATION_PRIVATE_KEY_PREFIX=
TACHI_CDN_SAVE_LOCATION_PRIVATE_REGION=

# Email (required)
TACHI_EMAIL_FROM=
TACHI_EMAIL_HOST=
TACHI_EMAIL_PORT=
TACHI_EMAIL_SECURE=
TACHI_EMAIL_AUTH_USER=
TACHI_EMAIL_AUTH_PASS=

# External game APIs (optional)
TACHI_FLO_API_URL=
TACHI_EAG_API_URL=
TACHI_MIN_API_URL=
TACHI_ARC_API_URL=
TACHI_MYT_API_HOST=
TACHI_ARC_AUTH_TOKEN=
TACHI_MYT_AUTH_TOKEN=

# OAuth2 - set all 3 for a provider or none
TACHI_FLO_OAUTH2_CLIENT_ID=
TACHI_FLO_OAUTH2_CLIENT_SECRET=
TACHI_FLO_OAUTH2_REDIRECT_URI=
TACHI_EAG_OAUTH2_CLIENT_ID=
TACHI_EAG_OAUTH2_CLIENT_SECRET=
TACHI_EAG_OAUTH2_REDIRECT_URI=
TACHI_MIN_OAUTH2_CLIENT_ID=
TACHI_MIN_OAUTH2_CLIENT_SECRET=
TACHI_MIN_OAUTH2_REDIRECT_URI=

# CG - set both for a suffix or neither
TACHI_CG_DEV_API_KEY=
TACHI_CG_DEV_URL=
TACHI_CG_NAG_API_KEY=
TACHI_CG_NAG_URL=
TACHI_CG_GAN_API_KEY=
TACHI_CG_GAN_URL=

# Seeds (optional) - set TACHI_SEEDS_TYPE to LOCAL_FILES or GIT_REPO to enable
TACHI_SEEDS_TYPE=
TACHI_SEEDS_PATH=
TACHI_SEEDS_REPO_URL=
TACHI_SEEDS_USER_NAME=
TACHI_SEEDS_USER_EMAIL=
TACHI_SEEDS_BRANCH=
# Required for automated seeds commit/push when TACHI_SEEDS_TYPE=GIT_REPO
GIT_USERNAME=
GIT_PASSWORD=

# Invite codes - set all 3 or none
TACHI_INVITE_CODE_BATCH_SIZE=
TACHI_INVITE_CODE_INVITE_CAP=
TACHI_INVITE_CODE_BETA_USER_BONUS=
