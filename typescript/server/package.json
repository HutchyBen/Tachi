{
	"name": "tachi-server",
	"version": "2.5.1",
	"description": "A score tracking server.",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "tap",
		"snap": "TAP_SNAPSHOT=1 tap",
		"watchtest": "tap --watch",
		"gen-proto": "grpc_tools_node_protoc --plugin=protoc-gen-ts=$(which protoc-gen-ts) --js_out=import_style=commonjs,binary:src/proto/generated --ts_out=service=grpc-node,mode=grpc-js:src/proto/generated --grpc_out=grpc_js:src/proto/generated --proto_path=src/proto/myt src/proto/myt/*/*.proto",
		"build": "tsgo -b tsconfig.build.json -v",
		"typecheck": "tsgo --noEmit",
		"lint": "eslint ./src",
		"lint-fix": "eslint ./src --fix",
		"start": "pnpm build && pnpm start-no-build",
		"start-no-build": "NODE_PATH=js/ node js/main.js",
		"start-score-worker": "NODE_PATH=js/ node js/lib/score-import/worker/worker.js",
		"load-seeds": "ts-node src/scripts/load-seeds",
		"recalc-everything": "ts-node src/scripts/state-sync/sync-state.ts",
		"make-user-admin": "ts-node src/scripts/make-user-admin.ts $@",
		"validate-database": "ts-node src/scripts/validate-database",
		"dev": "NODE_PATH=js/ nodemon",
		"set-indexes": "ts-node src/scripts/set-indexes.ts"
	},
	"author": "zk",
	"license": "AGPL3",
	"devDependencies": {
		"@grpc/grpc-js": "catalog:",
		"@types/google-protobuf": "catalog:",
		"@types/pg": "catalog:",
		"@types/supertest": "catalog:",
		"@types/tap": "catalog:",
		"@typescript/native-preview": "catalog:",
		"eslint-config-tachi": "workspace:*",
		"glob": "catalog:",
		"google-protobuf": "catalog:",
		"grpc-tools": "catalog:",
		"node-mocks-http": "catalog:",
		"nodemon": "catalog:",
		"supertest": "catalog:",
		"tap": "workspace:*",
		"ts-protoc-gen": "catalog:",
		"tsconfig-paths": "catalog:"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "catalog:",
		"@aws-sdk/signature-v4-crt": "catalog:",
		"@types/bcryptjs": "catalog:",
		"@types/bson": "catalog:",
		"@types/bunyan": "catalog:",
		"@types/connect-redis": "catalog:",
		"@types/express": "catalog:",
		"@types/express-rate-limit": "catalog:",
		"@types/express-serve-static-core": "catalog:",
		"@types/express-session": "catalog:",
		"@types/glob": "catalog:",
		"@types/mkdirp": "catalog:",
		"@types/mongodb": "catalog:",
		"@types/multer": "catalog:",
		"@types/node": "catalog:",
		"@types/node-fetch": "catalog:",
		"@types/nodemailer": "catalog:",
		"@types/rate-limit-redis": "catalog:",
		"@types/redis": "catalog:",
		"@types/rimraf": "catalog:",
		"@types/safe-json-stringify": "catalog:",
		"@types/semver": "catalog:",
		"@valuabletouch/winston-seq": "catalog:",
		"bcryptjs": "catalog:",
		"bms-table-loader": "catalog:",
		"bullmq": "catalog:",
		"bunyan": "catalog:",
		"commander": "catalog:",
		"connect-redis": "catalog:",
		"csv-parse": "catalog:",
		"deepmerge": "catalog:",
		"express": "catalog:",
		"express-async-errors": "catalog:",
		"express-prom-bundle": "catalog:",
		"express-rate-limit": "catalog:",
		"express-session": "catalog:",
		"fast-json-stable-hash": "catalog:",
		"fast-xml-parser": "catalog:",
		"helmet": "catalog:",
		"html-entities": "catalog:",
		"json5": "catalog:",
		"kysely": "catalog:",
		"mkdirp": "catalog:",
		"mongodb": "catalog:",
		"monk": "catalog:",
		"multer": "catalog:",
		"node-cache": "catalog:",
		"node-fetch": "catalog:",
		"node-html-parser": "catalog:",
		"nodemailer": "catalog:",
		"pg": "catalog:",
		"pino": "catalog:",
		"prudence": "catalog:",
		"rate-limit-redis": "catalog:",
		"redis": "catalog:",
		"rg-stats": "catalog:",
		"rimraf": "catalog:",
		"safe-json-stringify": "catalog:",
		"semver": "catalog:",
		"tachi-common": "workspace:*",
		"tachi-db": "workspace:*",
		"tachi-db-migration-engine": "workspace:*",
		"ts-node": "catalog:",
		"typescript": "catalog:",
		"uuidv7": "catalog:",
		"winston": "catalog:",
		"winston-loki": "catalog:",
		"winston-transport": "catalog:",
		"zod": "catalog:"
	},
	"nyc": {
		"reporter": [
			"html",
			"lcov"
		],
		"all": true,
		"include": [
			"src/*/!(test-utils)/**/*.ts"
		],
		"exclude": [
			"src/**/*.test.ts",
			"src/external/mongo/schemas.ts"
		]
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"imports": {
		"#*": [
			"./src/*",
			"./src/*.ts",
			"./src/*.d.ts",
			"./src/*/index.ts"
		]
	}
}
