{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100,
		"indentWidth": 4
	},
	"files": {
		"includes": [
			"**",
			"!db/src/generated",
			"!client/build",
			"!dist",
			"!vendor",
			"!seeds/collections",
			"!server/src/test-utils/test-data"
		]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"enabled": false
	},
	"assist": {
		"enabled": false
	}
}
